# Arc testnet RPC endpoint
RPC_URL=https://your-arc-testnet-rpc

# Safety chain guard (must match target network chain id)
EXPECTED_CHAIN_ID=

# Deployer private key (no 0x prefix)
PRIVATE_KEY=replace_with_private_key

# Final owner (recommended multisig). Defaults to deployer when omitted.
OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# If true and OWNER_ADDRESS != deployer, starts two-step ownership transfer.
TRANSFER_OWNERSHIP=false

# USDC token on Arc testnet
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Protocol config
PLATFORM_FEE_BPS=
DISPUTE_RESOLUTION_DELAY=
MIN_BID_SCORE=
ARC_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
